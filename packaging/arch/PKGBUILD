# Maintainer: tcraid0
pkgname=binder-bin
pkgver=1.0.0
pkgrel=1
pkgdesc='The reading app for markdown. Drop a file in, read it well.'
arch=('x86_64')
url='https://github.com/tcraid0/binder-app'
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'librsvg')
optdepends=('libayatana-appindicator: system tray support')
provides=('binder')
conflicts=('binder')
options=('!strip')
source=("${pkgname}-${pkgver}.AppImage::https://github.com/tcraid0/binder-app/releases/download/v${pkgver}/Binder_${pkgver}_amd64.AppImage"
        "LICENSE-${pkgver}::https://raw.githubusercontent.com/tcraid0/binder-app/v${pkgver}/LICENSE")
sha256sums=('SKIP'
            'SKIP')

prepare() {
    chmod +x "${srcdir}/${pkgname}-${pkgver}.AppImage"
    "${srcdir}/${pkgname}-${pkgver}.AppImage" --appimage-extract
}

package() {
    install -Dm755 "${srcdir}/squashfs-root/usr/bin/binder" "${pkgdir}/usr/bin/binder"

    # Desktop file is capitalized in the AppImage
    install -Dm644 "${srcdir}/squashfs-root/usr/share/applications/Binder.desktop" \
        "${pkgdir}/usr/share/applications/binder.desktop"

    for size in 32x32 128x128; do
        install -Dm644 "${srcdir}/squashfs-root/usr/share/icons/hicolor/${size}/apps/binder.png" \
            "${pkgdir}/usr/share/icons/hicolor/${size}/apps/binder.png"
    done

    # HiDPI icon
    install -Dm644 "${srcdir}/squashfs-root/usr/share/icons/hicolor/256x256@2/apps/binder.png" \
        "${pkgdir}/usr/share/icons/hicolor/256x256@2/apps/binder.png"

    install -Dm644 "${srcdir}/LICENSE-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
